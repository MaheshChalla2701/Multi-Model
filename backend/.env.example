# Google Gemini API Key (Required for inference and embeddings)
GEMINI_API_KEY="your_google_ai_studio_key_here"

# Qdrant Cloud (Vector DB)
QDRANT_URL="https://your-cluster-url.cloud.qdrant.io"
QDRANT_API_KEY="your_qdrant_api_key_here"

# Neo4j AuraDB (Graph DB)
NEO4J_URI="neo4j+s://your-instance-id.databases.neo4j.io"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="your_neo4j_password_here"

# MongoDB (Audit Database - Phase 4)
MONGODB_URL="mongodb://localhost:27017"

# CORS — comma-separated list of allowed frontend origins.
# For local development the default (http://localhost:3000) is used when this is unset.
# In production set this to your deployed frontend URL, e.g.:
# ALLOWED_ORIGINS="https://app.yourdomain.com"
ALLOWED_ORIGINS="http://localhost:3000"
